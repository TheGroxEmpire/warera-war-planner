# Copy to .env locally for server/port settings.

# Flask/server
FLASK_DEBUG=false
LOG_LEVEL=INFO
PORT=10000
WEB_PORT=10000
WEB_PUBLISHED_PORT=10000

# Optional Traefik override: docker compose -f docker-compose.yml -f docker-compose.traefik.yml up -d
TRAEFIK_ENABLE=true
TRAEFIK_ROUTER_NAME=warera-war-planner
TRAEFIK_SERVICE_NAME=warera-war-planner
TRAEFIK_ENTRYPOINT=https
TRAEFIK_TLS=true
TRAEFIK_PRIORITY=100
PROXY_NETWORK=proxy
WARERA_HOST=warera.yoursite.com
APP_BASE_PATH=/war-planner
